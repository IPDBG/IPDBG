<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Proxy" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/Proxy" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Option parameters="data.json" />
				<Compiler>
					<Add option="-g" />
					<Add directory="include" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/Proxy" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add directory="include" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
		</Compiler>
		<Linker>
			<Add option="`pkg-config jsoncpp --libs`" />
		</Linker>
		<Unit filename="include/concrete_proxy_states.h" />
		<Unit filename="include/proxy.h" />
		<Unit filename="include/proxy_state.h" />
		<Unit filename="include/tcp_client.h" />
		<Unit filename="include/tcp_server.h" />
		<Unit filename="main.cpp" />
		<Unit filename="src/concrete_proxy_states.cpp" />
		<Unit filename="src/proxy.cpp" />
		<Unit filename="src/tcp_client.cpp" />
		<Unit filename="src/tcp_server.cpp" />
		<Extensions />
	</Project>
</CodeBlocks_project_file>
